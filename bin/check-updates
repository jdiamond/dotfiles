#!/bin/bash
# Check for outdated packages across brew, npm (global), and bob.
# Usage: check-updates [--upgrade]

UPGRADE=false
if [[ "$1" == "--upgrade" || "$1" == "-u" ]]; then
  UPGRADE=true
fi

header() { printf "\n\033[1;34m==> %s\033[0m\n" "$1"; }
ok()     { printf "\033[0;32m%s\033[0m\n" "$1"; }

# --- Homebrew ---
header "Homebrew"
brew update -q
OUTDATED=$(brew outdated --verbose)
if [[ -z "$OUTDATED" ]]; then
  ok "Everything up to date"
else
  echo "$OUTDATED"
  if $UPGRADE; then
    header "Upgrading Homebrew packages"
    brew upgrade
  fi
fi

# --- npm global ---
if command -v npm &>/dev/null; then
  header "npm (global)"
  OUTDATED=$(npm outdated -g 2>/dev/null)
  if [[ -z "$OUTDATED" ]]; then
    ok "Everything up to date"
  else
    echo "$OUTDATED"
    if $UPGRADE; then
      header "Upgrading npm global packages"
      npm update -g
    fi
  fi
fi

# --- bob (Neovim) ---
if command -v bob &>/dev/null; then
  header "bob (Neovim)"
  bob list 2>/dev/null
  if $UPGRADE; then
    header "Upgrading Neovim via bob"
    bob update --all
  fi
fi
